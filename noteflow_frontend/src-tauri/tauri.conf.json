{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "NoteFlow",
  "version": "1.0.0",
  "identifier": "com.jefferyhuang.noteflow",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3015",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build --mode tauri "
  },
  "app": {
    "windows": [
      {
        "title": "NoteFlow",
        "width": 1600,
        "height": 1000,
        "resizable": true,
        "fullscreen": false,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "externalBin": [
      "bin/NoteFlowBackend/NoteFlowBackend"
    ],
    "resources": {
    "bin/NoteFlowBackend/_internal":"_internal"
    },
    "macOS":{
      "files": {
               "Frameworks": "bin/NoteFlowBackend/_internal"
      }
    },
    "active": true,
    "targets": "all",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": true
      }
    },
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJGOUI1NkM4MEVCMzk5NjgKUldSb21iTU95RmFidnhWVEFCUlFYWnljdDRZc2NVVnl1dVNzRVdyUjU3TWU3Mnk2RWFJZFRGaHMK",
      "endpoints": [
        "https://github.com/super-mortal/NoteFlow/releases/latest/download/update.json"
      ]
    }
  }
}
