# =============================================================================
# NoteFlow 环境变量示例
# Docker 部署：cp .env.example .env，按需修改，然后 docker-compose up --build -d
#
# 注意区分两类变量：
#   1) VITE_* 是【构建时】变量，会被烘进前端 JS bundle。改完必须
#      docker-compose build frontend && docker-compose up -d 才会生效，
#      只 docker-compose restart 不行。
#   2) 其他后端变量是【运行时】变量，改完 docker-compose up -d 即可。
#
# 提醒：LLM API key 不要写在这里！请部署完成后，从前端「模型供应商」页面录入，
#       这些 key 会保存到 SQLite 数据库（./backend/noteflow.db）并随容器持久化。
# =============================================================================

# 通用端口配置
BACKEND_PORT=8483           # 后端 FastAPI 服务端口
FRONTEND_PORT=3015          # 前端开发服务器端口
BACKEND_HOST=0.0.0.0        # 后端监听地址（0.0.0.0 表示监听所有网络接口，不建议修改）
APP_PORT=3015               # Docker 部署时对外暴露的端口（浏览器访问的端口）

# 前端访问后端配置（VITE_ 开头为构建时变量）
VITE_API_BASE_URL=http://127.0.0.1:8483                    # 前端调用后端 API 的地址
VITE_SCREENSHOT_BASE_URL=http://127.0.0.1:8483/static/screenshots  # 前端访问截图的地址
VITE_FRONTEND_PORT=3015                                     # 前端端口（与 FRONTEND_PORT 保持一致）

# 环境配置
ENV=production              # 运行环境：production 或 development

# 静态资源配置
STATIC=/static              # 静态资源 URL 前缀
OUT_DIR=./static/screenshots        # 截图本地输出目录
NOTE_OUTPUT_DIR=note_results        # 笔记文件输出目录
IMAGE_BASE_URL=/static/screenshots  # 图片访问 URL 路径
DATA_DIR=data               # 数据存储目录（SQLite、配置文件等）

# FFmpeg 配置
# Docker 镜像已内置 ffmpeg，留空即可
# 源码部署或桌面端可填写 ffmpeg 可执行文件的绝对路径
FFMPEG_BIN_PATH=

# 音频转写引擎配置
# TRANSCRIBER_TYPE 可选值：
#   - fast-whisper: 本地 Faster-Whisper（需下载模型，支持 GPU 加速）
#   - mlx-whisper: Apple Silicon 优化版本（仅 macOS M 系列芯片）
#   - groq: Groq 在线转写服务（需 API Key）
#   - bcut: 必剪在线转写
#   - kuaishou: 快手在线转写
#   - openai-compatible: OpenAI 兼容的转写服务（Groq、硅基流动等）
TRANSCRIBER_TYPE=fast-whisper

# Whisper 模型尺寸配置
# 可选值：tiny / base / small / medium / large-v1 / large-v2 / large-v3
# - tiny (~75MB): 最快，适合快速测试和低配置环境
# - base (~142MB): 平衡速度和准确度
# - small (~466MB): 较好的识别质量
# - medium (~1.5GB): 高质量识别（首次下载较慢，需足够内存）
# - large-v3 (~2.9GB): 最高质量（需 GPU 或高性能 CPU）
# 
# 注意：首次使用会自动下载模型，建议先用 tiny 测试，后续可在前端「音频转写配置」页切换
WHISPER_MODEL_SIZE=tiny

# Groq 转写配置（仅当 TRANSCRIBER_TYPE=groq 时生效）
GROQ_TRANSCRIBER_MODEL=whisper-large-v3-turbo  # Groq 提供的 Whisper 模型
