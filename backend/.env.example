
# 通用
ENV=production
API_BASE_URL=http://127.0.0.1:8000
SCREENSHOT_BASE_URL=http://127.0.0.1:8000/static/screenshots

# 数据目录（默认统一到 data/ 下；桌面端为安装目录/data/）
# 子目录：notes downloads screenshots models exports vector_db
DATA_DIR=data

# 静态文件路径
STATIC=/static
OUT_DIR=data/screenshots
IMAGE_BASE_URL=/static/screenshots

# 笔记输出目录（默认 data/notes/）
NOTE_OUTPUT_DIR=data/notes

# 数据库（默认 data/noteflow.db）
DATABASE_URL=sqlite:///data/noteflow.db

# ChromaDB 向量数据库
VECTOR_DB_DIR=data/vector_db

# transcriber 相关配置
TRANSCRIBER_TYPE=fast-whisper # fast-whisper/bcut/kuaishou
WHISPER_MODEL_SIZE=base